# -----------------------------------------------------------------------------
# CORE APP SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI & EXTERNAL APIS
# -----------------------------------------------------------------------------
# Get your Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Get your Brevo API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY="YOUR_BREVO_API_KEY"

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (BREVO)
# -----------------------------------------------------------------------------
SENDER_NAME="Lovely Professional University"
SENDER_EMAIL="admin@yourcollege.com"
EMAIL_SENDER_NAME="Lovely Professional University"
EMAIL_SENDER_ADDRESS="admin@yourcollege.com"
COLLEGE_NAME="Lovely Professional University"

# -----------------------------------------------------------------------------
# INFRASTRUCTURE (REDIS & DATABASE)
# -----------------------------------------------------------------------------
# In local development, the worker mocks Redis if this is empty.
REDIS_URL=redis://localhost:6379

# Prisma database URL (SQLite by default in schema.prisma)
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# SECURITY & AUTH (FOR FUTURE USE)
# -----------------------------------------------------------------------------
# JWT_SECRET="your_random_secret_key_here"

# -----------------------------------------------------------------------------
# WHATSAPP CLOUD API CONFIGURATION
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID="YOUR_PHONE_NUMBER_ID"
WHATSAPP_BUSINESS_ACCOUNT_ID="YOUR_BUSINESS_ACCOUNT_ID"
WHATSAPP_ACCESS_TOKEN="YOUR_WHATSAPP_ACCESS_TOKEN"
WHATSAPP_TEST_NUMBER="YOUR_TEST_NUMBER"
WHATSAPP_RECIPIENT_TEST="RECIPIENT_NUMBER"
WHATSAPP_VERIFY_TOKEN="student_platform_secret"
